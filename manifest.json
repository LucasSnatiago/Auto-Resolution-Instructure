{
  "manifest_version": 3,
  "name": "Instructure Video Auto-Resolution",
  "version": "1.0",
  "description": "Automatiza a troca de resolução de vídeos no Instructure.",
  "permissions": [
    "activeTab"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "instructure-video-fix@lucassnatiago.com.br",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.instructure.com/*",
        "*://*.instructuremedia.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
